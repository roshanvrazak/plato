        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ffokkem6vlwqod"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  t.name AS tenant,\n  t.daily_budget_pence / 100.0 AS \"Budget (£)\",\n  COALESCE(SUM(u.cost_pence), 0) / 100.0 AS \"Spent (£)\",\n  CASE WHEN t.daily_budget_pence = 0 THEN 0\n       ELSE ROUND(100.0 * COALESCE(SUM(u.cost_pence), 0) / t.daily_budget_pence, 1)\n  END AS \"Utilisation (%)\"\nFROM tenants t\nLEFT JOIN usage_log u\n  ON u.tenant_id = t.id\n AND u.status_code < 400\n AND u.created_at >= date_trunc('day', NOW() AT TIME ZONE 'Europe/London')\n                     AT TIME ZONE 'Europe/London' AT TIME ZONE 'UTC'\nGROUP BY t.name, t.daily_budget_pence\nORDER BY \"Utilisation (%)\" DESC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
